# =============================================================================
# Blitzy Platform API Test Suite — Environment Configuration Template
# =============================================================================
#
# Copy this file to .env and fill in the actual values before running the tests:
#   cp .env.example .env
#
# All variables marked as REQUIRED must be set for the test suite to function.
# Variables marked as OPTIONAL have sensible defaults and can be left unchanged.
#
# IMPORTANT: Never commit your .env file with real credentials to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# API Connection Settings (REQUIRED)
# -----------------------------------------------------------------------------

# Blitzy Platform API base URL (e.g., https://api.blitzy.com)
# This is the root URL for all API requests made by the test suite.
# Do not include a trailing slash.
BASE_URL=

# Authentication bearer token for API access
# Obtain from Blitzy Platform dashboard or admin settings.
# The token is sent as an Authorization header: "Bearer <API_TOKEN>"
API_TOKEN=

# -----------------------------------------------------------------------------
# Test Data Configuration (REQUIRED)
# -----------------------------------------------------------------------------

# Project ID with existing code generation runs
# Used for GET /runs/metering and GET /project endpoint tests.
# Must reference a project that has at least one completed code generation run.
TEST_PROJECT_ID=

# Specific run ID for targeted metering tests
# Used for verifying specific run metering data via GET /runs/metering.
# Must reference a valid code generation run within the test project.
TEST_RUN_ID=

# -----------------------------------------------------------------------------
# Optional Test Configuration
# -----------------------------------------------------------------------------

# Test execution timeout in seconds (default: 30)
# Individual API calls that exceed this duration will be marked as failed.
TEST_TIMEOUT=30

# Log level for test output (DEBUG, INFO, WARNING, ERROR)
# Set to DEBUG for verbose request/response logging during troubleshooting.
LOG_LEVEL=INFO
